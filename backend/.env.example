# Copy this file to .env and fill in real values before running the server.

# --- Server ---
PORT=4000
NODE_ENV=development
# Set this to your frontend's real origin in production, e.g. https://jumpstart.bg
CORS_ORIGIN=*

# --- Auth ---
# Any long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

# --- Database ---
# OPTION A: single connection string (used by most hosts — Railway, Render,
# Supabase, Neon, etc. all give you one of these). If set, it takes priority
# over the individual PG* vars below.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# OPTION B: individual vars (used for local development against a
# PostgreSQL instance running on your own machine).
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=jumpstart

# Set to "false" only if your DATABASE_URL host does not support/require SSL
# (e.g. a local Docker Postgres reached via a connection string).
PGSSL=true

# --- Email (registration verification codes, forgot password) ---
# Sent via the EmailJS REST API (HTTPS) rather than SMTP, since Render and
# most PaaS hosts block outbound SMTP ports. Create a service + template at
# emailjs.com, connect your Gmail account to it, and enable "Allow EmailJS
# API for non-browser applications" under Account -> Security. Leave any of
# these unset to just log codes to the console instead of sending.
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
# Used as the "from"/reply-to address for the contact form only.
EMAIL_USER=

# --- AI chat widget (GitHub Models — free via your GitHub account) ---
# Fine-grained personal access token with "Models: Read-only" permission:
# https://github.com/settings/tokens?type=beta
GITHUB_MODELS_TOKEN=
